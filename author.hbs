{{!< default}}

<div class="content-area custom-page">
    <main class="site-main" id="main">
        <div class="wrapper" data-width="medium">
            <div class="error-content">
                <h1 class="error-title hero-header">Redirecting to About</h1>
                <p class="error-body body-2 hero-desc">This site does not use separate author archive pages.</p>
                <p class="error-body body-2 hero-desc"><a href="{{@site.url}}/about/">Go to the About page</a>.</p>
            </div>
        </div>
    </main>
</div>

<script>
    window.location.replace('{{@site.url}}/about/');
</script>

{{#contentFor "body_class"}}redirect-author{{/contentFor}}
