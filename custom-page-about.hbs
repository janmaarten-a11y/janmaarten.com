{{!< default}}
{{!--
    Custom page template — About.
    Select this template in Ghost Admin on the page with slug `about`.

    Layout:
      1. Page header (title + custom_excerpt as bio strapline + optional
         feature image as portrait) — reuses the existing `page-header`
         partial, same treatment as the Works page.
      2. Page body content via {{content}} — author writes the bio,
         "How I work" principles, and "What I do" capability blocks
         directly in the Ghost editor.
      3. Speaking section — auto-queried from pages tagged with the
         internal `#content-experience` tag (same source as the old
         Works page section that has been removed).
      4. Endorsements section — auto-queried from pages tagged with
         the internal `#content-testimonial` tag (same source as the
         old Works page section that has been removed).
--}}

<div class="content-area custom-page">
    <main class="site-main flow" id="main">

        {{> "page-header"}}

        {{#post}}
            {{#if html}}
                <section class="wrapper">
                    <div class="single-content gh-content">
                        {{content}}
                    </div>
                </section>
            {{/if}}
        {{/post}}

        {{!-- Fluid section (see assets/css/blog/fluid-section.css) — a reusable
              header + adaptive card grid. Reuse the classes for any section of
              this shape; do not fork the CSS. The header (eyebrow/title/intro)
              is authored here per use. The cards below are placeholder content;
              to make them tag-driven later, replace the hardcoded <li>s with a
              loop over the fluid-card partial, e.g.:
                {{#get "pages" filter="tag:hash-content-value" order="published_at asc"}}
                  <ul class="fluid-grid" role="list">
                    {{#foreach pages}}{{> "components/fluid-card"}}{{/foreach}}
                  </ul>
                {{/get}}
              The fluid-card partial already supports feature images. --}}
        <section class="section-container fluid-section">
            <div class="fluid-section-body wrapper">
                <header class="fluid-section-header flow">
                    <p class="fluid-section-eyebrow">What drives the work</p>
                    <h2 class="fluid-section-title">Values</h2>
                    <p class="fluid-section-intro">A few principles I keep coming back to.</p>
                </header>
                <ul class="fluid-grid" role="list">
                    <li class="fluid-card">
                        <div class="fluid-card-body">
                            <h3 class="fluid-card-title">Accessibility is the baseline</h3>
                            <p class="fluid-card-desc">Inclusion is not a feature to bolt on at the end. It is the floor everything else is built on.</p>
                        </div>
                    </li>
                    <li class="fluid-card">
                        <div class="fluid-card-body">
                            <h3 class="fluid-card-title">Systems over one-offs</h3>
                            <p class="fluid-card-desc">Fix the pattern, not just the page. Durable solutions live in the design system, not in a single PR.</p>
                        </div>
                    </li>
                    <li class="fluid-card">
                        <div class="fluid-card-body">
                            <h3 class="fluid-card-title">Lived experience leads</h3>
                            <p class="fluid-card-desc">The people who rely on assistive technology are the experts. Test with them, not just for them.</p>
                        </div>
                    </li>
                    <li class="fluid-card">
                        <div class="fluid-card-body">
                            <h3 class="fluid-card-title">Clarity is a kindness</h3>
                            <p class="fluid-card-desc">Plain language, honest documentation, and legible interfaces respect people's time and attention.</p>
                        </div>
                    </li>
                </ul>
            </div>
        </section>

        {{!-- Speaking — pulled from pages tagged hash-content-experience.
              Title can be overridden per page via the post's custom field
              labelled "Speaking title" if you want a different heading. --}}
        <section class="section-container experiences section-experiences">
            <header class="feed-header wrapper">
                <div class="feed-header-wrapper">
                    <h2 class="section-title feed-header-title">Speaking</h2>
                </div>
            </header>
            {{#get "pages" include="tags" filter="tag:hash-content-experience" order="published_at desc"}}
                <div class="wrapper">
                    {{#foreach pages}}
                        {{> "components/experience" }}
                    {{/foreach}}
                </div>
            {{/get}}
        </section>

        {{!-- Endorsements — pulled from pages tagged hash-content-testimonial.
              Limit 6 matches the previous Works page treatment so the page
              doesn't get bottom-heavy; raise it if you want more on display. --}}
        <section class="section-container testimonials section-testimonials">
            <header class="feed-header wrapper">
                <div class="feed-header-wrapper">
                    <h2 class="section-title feed-header-title">Endorsements</h2>
                </div>
            </header>
            {{#get "pages" include="tags" filter="tag:hash-content-testimonial" limit="6" order="published_at desc"}}
                <div class="testimonials-list wrapper">
                    {{#foreach pages}}
                        {{> "components/testimonial" }}
                    {{/foreach}}
                </div>
            {{/get}}
        </section>

    </main>
</div>

{{#contentFor "body_class"}}{{#if @member}} logged-in{{/if}}{{/contentFor}}
