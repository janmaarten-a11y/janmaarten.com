{{!< default}}

<div class="content-area">
    <main class="site-main flow" id="main">
        {{#tag}}
            <section class="wrapper">
                <div class="hero-wrapper flow">
                    <h1 class="h1 hero-header">{{name}}</h1>

                    {{#if description}}
                        <p class="body-1 hero-desc">{{description}}</p>
                    {{/if}}
                </div>
            </section>
        {{/tag}}

        <section class="section-container reset-spacing">
            <div class="post-feed gh-feed wrapper{{#match @custom.feed_layout "!=" "Minimal"}} expanded{{/match}}{{#match @custom.feed_layout "Right thumbnail"}} right-thumbnail{{/match}}{{#match @custom.feed_layout "Text-only"}} text-only{{/match}}">
                {{#foreach posts}}
                    {{> "loop" noDate=false}}
                {{/foreach}}
            </div>

            {{pagination}}
        </section>

        {{#tag}}
            {{#get "tags" limit="16" include='count.posts' order='count.posts desc' filter="id:-{{id}}+visibility:public" as |tags|}}
                {{#if tags}}
                    <section class="section-container">
                        <header class="feed-header wrapper">
                            <div class="feed-header-wrapper">
                                <h2 class="section-title feed-header-title">{{t "Explore more topics"}}</h2>
                            </div>
                        </header>

                        <div class="tag-list-wrapper wrapper">
                            <div class="tag-topic-list">
                                {{#foreach tags}}
                                    {{#if count.posts}}
                                        <a class="tag-topic-card{{#if feature_image}} has-image{{/if}}" href="{{url}}" style="--tag-accent: {{accent_color}};">
                                            {{#if feature_image}}
                                                <span class="tag-topic-card-media u-placeholder square">
                                                    <img class="u-object-fit" src="{{img_url feature_image size="s"}}" alt="{{name}}">
                                                </span>
                                            {{/if}}

                                            <span class="tag-topic-card-content">
                                                <span class="tag-topic-card-name">{{name}}</span>
                                                <span class="tag-topic-card-count">{{count.posts}} posts</span>
                                            </span>
                                        </a>
                                    {{/if}}
                                {{/foreach}}
                            </div>
                        </div>
                    </section>
                {{/if}}
            {{/get}}
        {{/tag}}

    </main>
</div>

{{#contentFor "body_class"}}{{#if next}} paged-next{{/if}}{{#if @site.logo}}{{#if @site.cover_image}} with-alt-header{{/if}}{{/if}}{{/contentFor}}