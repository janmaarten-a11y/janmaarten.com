{{!< default}}

<div class="content-area">
    <main class="site-main site-layout" id="main">
        {{#get "pages" filter="tags:hash-home-intro" include="tags" limit="1"}}
            {{#if pages}}
                {{#foreach pages}}
                    <section class="{{post_class}} container wide gh-content section-hero hero-intro">
                        {{ content }}
                        {{#unless @member}}
                            {{#if @site.members_enabled}}
                                <div class="subscription-wrapper">
                                    <div class="body-1 subscribe-title"> {{@custom.email_signup_text}} </div>
                                    {{> "subscription-box"}}
                                </div>
                            {{/if}}
                        {{/unless}}
                    </section>
                {{/foreach}}
            {{else}}
                <section class="container wide section-hero">
                    <div class="hero-wrapper">
                        <h1 class="h1 home-hero-header">{{@custom.hero_text}}</h1>
                        {{#if @site.description}}
                            <p class="body-1 hero-desc"> {{@site.description}}</p>
                        {{/if}}
                    </div>
                </section>
            {{/if}}
        {{/get}}

        {{#get "pages" filter="tags:hash-section-logos" order="published_at asc" limit="1"}}
            {{#foreach pages}}
                <section class="section-container logo-board section-logo-board">
                    <header class="feed-header container wide">
                        <h2 class="section-title feed-header-title">{{title}}</h2>
                    </header>
                    <div class="container wide logo-list">
                        {{content}}
                    </div>
                </section>
            {{/foreach}}
        {{/get}}

        {{#if @custom.personal_project_title}}
            <section class="section-container section-personal-project">
                <header class="feed-header container wide">
                    <div class="feed-header-wrapper">
                        <h2 class="section-title feed-header-title">{{@custom.personal_project_title}}</h2>
                    </div>
                </header>
                {{#get "pages" filter="tag:hash-content-personal-project" order="published_at desc"}}
                    <div class="cards kg-grid kg-grid-2col gh-feed container wide">
                        {{#foreach pages}}
                            {{> "components/card-project" showExcerpt=true showVisual=true isSmall=true}}
                        {{/foreach}}
                    </div>
                {{/get}}
            </section>
        {{/if}}

        {{#if @custom.feed_title}}
            <section class="section-container section-blog">
                <header class="feed-header container wide">
                    <div class="feed-header-wrapper">
                        <h2 class="section-title feed-header-title">{{@custom.feed_title}}</h2>
                    </div>
                </header>
                {{#get "posts" limit="50" include="tags" filter="tag:-[books,now,hash-timeline,hash-overlays]"}}
                    <div class="post-feed{{#match @custom.feed_layout "!=" "Minimal"}} expanded{{/match}}{{#match @custom.feed_layout "Right thumbnail"}} right-thumbnail{{/match}}{{#match @custom.feed_layout "Text-only"}} text-only{{/match}} gh-feed container wide">
                        {{#foreach posts}}
                            {{> "loop" noDate=false}}
                        {{/foreach}}
                    </div>
                {{/get}}
                <div class="container wide">
                    <a href="/blog/" class="button button-secondary round">{{t 'View all posts' count=pagination.total}} {{> "icons/arrow-right"}}</a>
                </div>
            </section>
        {{/if}}

        {{#if @custom.case_study_title}}
            <section class="section-container case-study section-case-study">
                <header class="feed-header container wide">
                        <div class="feed-header-wrapper">
                            <h2 class="section-title feed-header-title">{{@custom.case_study_title}}</h2>
                        </div>
                </header>
                {{#get "pages" include="tags" filter="tag:hash-content-case-study" limit="4" order="published_at desc"}}
                    <div class="cards kg-grid {{#match @custom.card_style "Full row"}}full-row{{else}}kg-grid-2col{{/match}} gh-feed container wide">
                        {{#foreach pages}}
                            {{> "components/card-project" showVisual=true isOverlay=true isLarge=true postFeedStyle=@custom.card_style }}
                        {{/foreach}}
                    </div>
                {{/get}}
                <div class="button-center">
                    <a href="/works/" class="button button-secondary round">{{t 'View all'}} {{> "icons/arrow-right"}}</a>
                </div>
            </section>
        {{/if}}

        {{#if @custom.testimonial_title }}
            <section class="section-container testimonials section-testimonials">
                <header class="feed-header container wide">
                        <div class="feed-header-wrapper">
                            <h2 class="section-title feed-header-title">{{@custom.testimonial_title}}</h2>
                        </div>
                </header>
                {{#get "pages" include="tags" filter="tag:hash-content-testimonial" limit="4" order="published_at desc"}}
                    <div class="cards kg-grid kg-grid-2col container wide">
                        {{#foreach pages}}
                            {{> "components/testimonial" }}
                        {{/foreach}}
                    </div>
                {{/get}}
            </section>
        {{/if}}

        {{#get "pages" filter="tags:hash-section-experiences" order="published_at asc" limit="1"}}
            {{#foreach pages}}
                <section class="section-container experiences section-experiences">
                    <header class="feed-header container wide">
                        <div class="feed-header-wrapper">
                            <h2 class="section-title feed-header-title">{{title}}</h2>
                        </div>
                    </header>
                    {{#get "pages" include="tags" filter="tag:hash-content-experience" order="published_at desc"}}
                        <div class="container wide">
                            {{#foreach pages}}
                                {{> "components/experience" }}
                            {{/foreach}}
                        </div>
                    {{/get}}
                </section>
            {{/foreach}}
        {{/get}}

        <section class="section-container">
            <div class="webring container wide">
                <h2 id="a11y-webring-club">a11y-webring.club</h2>
                <nav class="a11y-webring-club" aria-labelledby="a11y-webring-club">
                    <p>This site is a member of the <a rel="external" href="https://a11y-webring.club/" style="white-space: nowrap;">a11y-webring.club</a>.</p>
                    <ul class="webring-nav">
                        <li><a rel="external" referrerpolicy="strict-origin" href="https://a11y-webring.club/prev">Previous website</a></li>
                        <li><a rel="external" referrerpolicy="strict-origin" href="https://a11y-webring.club/random">Random website</a></li>
                        <li><a rel="external" referrerpolicy="strict-origin" href="https://a11y-webring.club/next">Next website</a></li>
                    </ul>
                </nav>
            </div>
        </section>

    </main>
</div>

{{#contentFor "body_class"}}{{#if next}} paged-next{{/if}}{{#if @member}} logged-in{{/if}}{{/contentFor}}
