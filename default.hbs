<!DOCTYPE html>
<html lang="{{@site.locale}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="webmention" href="https://webmention.io/janmaarten.com/webmention">
    <link rel="pingback" href="https://webmention.io/janmaarten.com/xmlrpc">

    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    <script>
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);
            var toggle = document.querySelector('.gh-theme-toggle');
            if (toggle) { toggle.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false'); }
        }
        function getSystemTheme() {
            return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        function toggleTheme() {
            var current = document.documentElement.getAttribute('data-theme');
            setTheme(current === 'dark' ? 'light' : 'dark');
        }
        (function() {
            var saved = localStorage.getItem('theme');
            if (saved) { setTheme(saved); }
            else { setTheme(getSystemTheme()); }
        })();
        window.matchMedia('(prefers-color-scheme: dark)').addListener(function(e) {
            if (!localStorage.getItem('theme')) { setTheme(e.matches ? 'dark' : 'light'); }
        });
    </script>
    {{ghost_head}}
</head>

<body class="{{body_class}}{{block "body_class"}}{{#match @custom.title_font "=" "Elegant serif"}} has-serif-title{{/match}}{{#match @custom.body_font "=" "Elegant serif"}} has-serif-body{{/match}}">
<div class="site">
    {{#post}}{{#has tag="#long-form"}}<progress class="reading-progress" value="0" max="100" aria-label="Reading progress"></progress>{{/has}}{{/post}}
    <header id="gh-head" class="gh-head gh-outer">
        <a class="skip-to-content-link" href="#main">
            Skip to content
        </a>
        <div class="gh-head-inner wrapper {{#unless @custom.profile_photo}}no-profile{{/unless}}">
                <div class="gh-head-brand">
                    <div class="gh-head-brand-wrapper">
                        <div class="gh-head-logo-text">
                            {{#if @site.logo }}
                                <a href="{{@site.url}}">
                                    <figure class="gh-head-logo-wrapper">
                                        <img
                                            srcset="{{img_url @site.logo size="s" format="webp"}} 400w"
                                            sizes="480px"
                                            src="{{img_url @site.logo size="s"}}"
                                            alt="{{@site.title}}"
                                            loading="lazy"
                                        >
                                    </figure>
                                </a>
                            {{else}}
                                <a class="h1" href="{{@site.url}}">
                                    {{@site.title}}
                                </a>
                            {{/if}}
                        </div>
                        {{#if @custom.tagline_text }}
                            <div class="sub-heading tagline">
                                {{@custom.tagline_text}}
                            </div>
                        {{/if}}
                    </div>
                    <button class="gh-search gh-icon-btn" aria-label="Search this site" data-ghost-search>{{> "icons/search"}}</button>
                    <button class="gh-burger"></button>
                </div>

                <nav class="gh-head-menu">
                    {{navigation}}
                    <button class="gh-theme-toggle gh-icon-btn" onclick="toggleTheme()" aria-label="Dark mode" aria-pressed="false" title="Toggle dark mode">
                        <div class="theme-toggle-icon">
                            <div class="moon-or-sun"></div>
                            <div class="moon-mask"></div>
                        </div>
                    </button>
                </nav>
            {{#if @custom.profile_photo }}
                <div class="gh-head-actions">
                    <div class="gh-head-brand-wrapper">
                        <a class="head-logo-wrap" href="{{@site.url}}">
                            <figure class="head-logo round">
                                <img
                                    srcset="{{img_url @custom.profile_photo size="s" format="webp"}} 400w"
                                    sizes="48px"
                                    src="{{img_url @custom.profile_photo size="s"}}"
                                    alt="{{@site.title}}"
                                    loading="lazy"
                                    class="u-object-fit"
                                >
                            </figure>
                        </a>
                    </div>
                </div>
            {{/if}}
        </div>
    </header>

    <div class="site-content flow">
        {{{body}}}
    </div>
    {{> footer}}
    <a style="display:none" rel="me" href="https://mastodon.social/@janmaarten">Mastodon</a>
</div>

{{#is "post, page"}}
    {{> "pswp"}}
{{/is}}

<script src="{{asset "built/main.min.js"}}"></script>
<script src="{{asset "js/prism.js"}}"></script>

{{!-- TOC — init when .toc-desktop or .toc-mobile exists (#show-toc posts) --}}
<script src="{{asset "js/tocbot.js"}}"></script>
<script>
(function() {
    var desktop = document.querySelector('.toc-desktop');
    var mobile = document.querySelector('.toc-mobile');
    if (!desktop && !mobile) return;

    // Init tocbot for desktop nav
    if (desktop) {
        tocbot.init({
            tocSelector: '.toc-desktop .toc',
            contentSelector: '.single-content',
            headingSelector: 'h2, h3',
            hasInnerContainers: true,
            ignoreSelector: '.toc-ignore',
            headingsOffset: 120,
            scrollSmooth: false,
        });
    }

    // Clone TOC into mobile nav
    if (desktop && mobile) {
        var desktopList = desktop.querySelector('.toc-list');
        var mobileNav = mobile.querySelector('.toc-mobile-nav');
        if (desktopList && mobileNav) {
            mobileNav.appendChild(desktopList.cloneNode(true));
        }
    }

    // Desktop: auto-collapse based on scroll position
    if (desktop) {
        var details = desktop.querySelector('.toc-details');
        var manualToggle = false;
        var content = document.querySelector('.single-content');
        var stickyTop = 24; // px from viewport top once scrolled past content start
        var collapseThreshold = window.innerHeight * 0.5;

        // Recalculate content top — call after images load or layout shifts
        var contentTextTop = 0;
        function recalcContentTop() {
            if (!content) return;
            var contentMarginTop = parseFloat(getComputedStyle(content).marginTop);
            contentTextTop = content.getBoundingClientRect().top + window.scrollY + contentMarginTop;
        }
        recalcContentTop();

        // Recalculate when feature image (or any image) finishes loading
        var article = document.querySelector('.single-header');
        if (article) {
            var imgs = article.querySelectorAll('img');
            imgs.forEach(function(img) {
                if (!img.complete) {
                    img.addEventListener('load', recalcContentTop);
                }
            });
        }
        // Final recalculate once all resources are loaded
        window.addEventListener('load', function() {
            recalcContentTop();
            updateTocPosition();
            desktop.classList.add('is-positioned');
        });

        // Also reveal on scroll — user may scroll before images finish
        window.addEventListener('scroll', function revealOnScroll() {
            recalcContentTop();
            updateTocPosition();
            desktop.classList.add('is-positioned');
            window.removeEventListener('scroll', revealOnScroll);
        }, { passive: true });

        // Sliding active marker — uses MutationObserver, not scroll
        var tocList = desktop.querySelector('.toc-list');
        var marker = document.createElement('div');
        marker.className = 'toc-active-marker';
        marker.style.display = 'none';
        if (tocList) tocList.appendChild(marker);

        function updateMarkerPosition() {
            if (!tocList) return;
            // Find the deepest active item (h3 inside h2, or h2 itself)
            var allActive = tocList.querySelectorAll('.toc-list-item.is-active-li');
            var active = allActive.length ? allActive[allActive.length - 1] : null;
            if (!active) return; // keep last position, don't hide
            marker.style.display = '';
            var link = active.querySelector(':scope > a');
            var fontSize = link ? parseFloat(getComputedStyle(link).fontSize) : 14;
            // Sum offsetTop up the chain to the root toc-list
            var top = parseFloat(getComputedStyle(active).paddingTop) + fontSize * 0.3;
            var el = active;
            while (el && el !== tocList) {
                top += el.offsetTop;
                el = el.offsetParent;
            }
            marker.style.top = top + 'px';
        }

        // Watch for tocbot class changes instead of polling on scroll
        if (tocList) {
            var observer = new MutationObserver(function() {
                updateMarkerPosition();
            });
            observer.observe(tocList, {
                attributes: true,
                attributeFilter: ['class'],
                subtree: true,
            });
        }

        // Align TOC vertically with the top of body text (not above it)
        function updateTocPosition() {
            if (!content) return;
            var textViewportTop = contentTextTop - window.scrollY;
            var tocHeight = desktop.offsetHeight;
            var contentBottom = content.getBoundingClientRect().bottom;
            var maxTop = contentBottom - tocHeight;

            // Hide TOC when it would overlap below the content area
            if (maxTop < stickyTop) {
                desktop.style.visibility = 'hidden';
            } else {
                desktop.style.visibility = '';
                desktop.style.top = Math.max(stickyTop, Math.min(textViewportTop, maxTop)) + 'px';
            }
        }

        // Track manual toggle: user clicked summary
        if (details) {
            details.addEventListener('toggle', function() {
                manualToggle = true;
            });
        }

        // Collapse state based on scroll position
        var autoCollapsed = false;

        function updateCollapseState() {
            if (manualToggle || !details) return;
            if (autoCollapsed && details.open) {
                details.open = false;
            } else if (!autoCollapsed && !details.open) {
                details.open = true;
            }
        }

        // If page is already scrolled past threshold on load, start collapsed
        var scrolledPastThreshold = (window.scrollY - contentTextTop) > collapseThreshold;
        if (scrolledPastThreshold && details) {
            autoCollapsed = true;
            details.open = false;
        }

        updateTocPosition();

        // Update position + auto-collapse on scroll
        if (content) {
            window.addEventListener('scroll', function() {
                updateTocPosition();

                if (manualToggle) return;
                var scrolledPast = window.scrollY - contentTextTop;
                autoCollapsed = scrolledPast > collapseThreshold;
                updateCollapseState();
            }, { passive: true });
        }

        // Initial marker position (tocbot may take a moment to set active class)
        setTimeout(updateMarkerPosition, 200);

        // Scroll page to TOC when summary receives keyboard focus,
        // since position:fixed prevents browser auto-scroll-into-view.
        // Skip for mouse/touch — mousedown sets a flag that focus checks.
        var summary = desktop.querySelector('.toc-header');
        if (summary) {
            var mouseTriggered = false;
            summary.addEventListener('mousedown', function() {
                mouseTriggered = true;
            });
            summary.addEventListener('focus', function() {
                if (mouseTriggered) {
                    mouseTriggered = false;
                    return;
                }
                if (window.scrollY < contentTextTop - stickyTop) {
                    window.scrollTo(0, contentTextTop - stickyTop);
                }
            });
        }
    }
})();
</script>

{{!-- Progress --}}
{{#is "post"}}
  <script>
    const progressBar = document.querySelector('.reading-progress');

    function updateProgress() {
      const totalHeight = document.body.clientHeight;
      const windowHeight = document.documentElement.clientHeight;
      const position = window.scrollY;
      const progress = position / (totalHeight - windowHeight) * 100;
      progressBar.setAttribute('value', progress);
      requestAnimationFrame(updateProgress);
    }

    requestAnimationFrame(updateProgress);
  </script>
{{/is}}
{{!-- Progress --}}

{{#is "post"}}
<script src="{{asset "js/webmention.js"}}" defer></script>
{{/is}}

{{ghost_foot}}

</body>
</html>
